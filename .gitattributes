# Force LF line endings for files that must be exec'd inside Linux containers.
# On Windows, git's default core.autocrlf=true converts these to CRLF on
# checkout, which makes the shebang line "#!/bin/bash\r" -- the kernel then
# can't find "/bin/bash\r" as the interpreter and Docker reports a misleading
# "exec ...: no such file or directory" error.
*.sh         text eol=lf
*.bash       text eol=lf
Dockerfile*  text eol=lf

# Mongo shell / Node scripts read inside Linux containers -- safer as LF too.
*.js         text eol=lf
